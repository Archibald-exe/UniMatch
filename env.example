import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  User, 
  Rocket, 
  MessageSquare, 
  Search, 
  Plus, 
  Check, 
  X, 
  Heart,
  Send, 
  ArrowRight,
  LogOut,
  Briefcase,
  GraduationCap,
  Tag,
  Link as LinkIcon,
  ChevronRight,
  LayoutDashboard,
  Zap,
  Target,
  Cpu,
  Palette,
  Users
} from 'lucide-react';
import {
  Radar, RadarChart, PolarGrid, 
  PolarAngleAxis, PolarRadiusAxis, ResponsiveContainer
} from 'recharts';

// --- Types ---
interface UserProfile {
  id: string;
  email: string;
  name: string;
  role: 'Student' | 'Founder' | 'Both';
  major: string;
  bio: string;
  skills: string[];
  mindset: {
    vision: number;
    execution: number;
    design: number;
    technical: number;
    social: number;
  };
  portfolio: {
    title: string;
    link: string;
    description: string;
    tags?: string[];
    image?: string;
  }[];
  avatar: string;
  match_count: number;
}

interface Project {
  id: string;
  founder_id: string;
  founder_name?: string;
  founder_avatar?: string;
  project_image?: string;
  title: string;
  pitch: string;
  stage: 'Idea' | 'MVP' | 'Scaling';
  roles_needed: string[];
  links: string;
  status: 'active' | 'archived';
  created_at: string;
}

interface Application {
  id: string;
  project_id: string;
  applicant_id: string;
  applicant_name?: string;
  applicant_avatar?: string;
  applicant_major?: string;
  applicant_mindset?: string; // JSON string from server
  message: string;
  status: 'pending' | 'accepted' | 'rejected';
}

interface Chat {
  id: string;
  project_id: string;
  project_title: string;
  user1_id: string;
  user1_name: string;
  user1_avatar: string;
  user2_id: string;
  user2_name: string;
  user2_avatar: string;
}

interface Message {
  id: string;
  chat_id: string;
  sender_id: string;
  content: string;
  type: 'text' | 'image';
  created_at: string;
}

// --- Components ---

const Button = ({ children, onClick, variant = 'primary', className = '', disabled = false, type = 'button' }: any) => {
  const base = "px-6 py-3 border-4 border-black font-display font-black uppercase italic tracking-tighter transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed brutalist-shadow-sm brutalist-shadow-hover brutalist-shadow-active";
  const variants: any = {
    primary: "bg-brand-blue text-white",
    secondary: "bg-white text-black",
    accent: "bg-brand-yellow text-black",
    danger: "bg-brand-red text-white",
    ghost: "border-none shadow-none hover:bg-black/5",
  };
  return (
    <button type={type} disabled={disabled} onClick={onClick} className={`${base} ${variants[variant]} ${className}`}>
      {children}
    </button>
  );
};

const Card = ({ children, className = '', noPadding = false, onClick }: any) => (
  <motion.div 
    whileHover={onClick ? { scale: 1.01 } : {}}
    onClick={onClick}
    className={`bg-white border-4 border-black brutalist-shadow ${noPadding ? '' : 'p-6'} ${onClick ? 'cursor-pointer' : ''} ${className}`}
  >
    {children}
  </motion.div>
);

const Input = ({ label, ...props }: any) => (
  <div className="mb-4">
    <label className="block font-display font-black uppercase italic text-xs tracking-tight mb-1">{label}</label>
    <input {...props} className="w-full bg-white border-4 border-black p-3 font-bold focus:outline-none focus:bg-brand-cyan/20 transition-all" />
  </div>
);

const TextArea = ({ label, ...props }: any) => (
  <div className="mb-4">
    <label className="block font-display font-black uppercase italic text-xs tracking-tight mb-1">{label}</label>
    <textarea {...props} className="w-full bg-white border-4 border-black p-3 font-bold focus:outline-none focus:bg-brand-cyan/20 transition-all min-h-[100px]" />
  </div>
);

const MindsetDiagram = ({ data, size = 200 }: { data: any, size?: number }) => {
  const chartData = [
    { subject: 'Vision', A: data.vision || 50, fullMark: 100 },
    { subject: 'Execution', A: data.execution || 50, fullMark: 100 },
    { subject: 'Design', A: data.design || 50, fullMark: 100 },
    { subject: 'Technical', A: data.technical || 50, fullMark: 100 },
    { subject: 'Social', A: data.social || 50, fullMark: 100 },
  ];

  return (
    <div style={{ width: size, height: size }} className="mx-auto flex items-center justify-center overflow-visible">
      <ResponsiveContainer width="100%" height="100%">
        <RadarChart cx="50%" cy="50%" outerRadius="40%" data={chartData} margin={{ top: 25, right: 25, bottom: 25, left: 25 }} style={{ overflow: 'visible' }}>
          <PolarGrid stroke="#e2e8f0" />
          <PolarAngleAxis 
            dataKey="subject" 
            tick={(props: any) => {
              const { x, y, payload, textAnchor, index } = props;
              // Adjust vertical position based on index to prevent overlapping or cutting off
              let dy = 0;
              if (index === 0) dy = -10; // Top
              if (index === 1 || index === 4) dy = -2; // Top-ish sides
              if (index === 2 || index === 3) dy = 12; // Bottom-ish sides
              
              return (
                <text
                  x={x}
                  y={y}
                  dy={dy}
                  textAnchor={textAnchor}
                  fill="#000"
                  fontSize={9}
                  fontWeight="900"
                  fontFamily="Space Grotesk"
                  className="uppercase italic"
                >
                  {payload.value}
                </text>
              );
            }}
          />
          <Radar
            name="Mindset"
            dataKey="A"
            stroke="#7FB3D5"
            fill="#7FB3D5"
            fillOpacity={0.6}
          />
        </RadarChart>
      </ResponsiveContainer>
    </div>
  );
};

// --- Main App ---

export default function App() {
  const [user, setUser] = useState<UserProfile | null>(null);
  const [view, setView] = useState<'auth' | 'onboarding' | 'feed' | 'dashboard' | 'profile' | 'chats'>('auth');
  const [projects, setProjects] = useState<Project[]>([]);
  const [myProjects, setMyProjects] = useState<Project[]>([]);
  const [chats, setChats] = useState<Chat[]>([]);
  const [activeChat, setActiveChat] = useState<Chat | null>(null);
  const [loading, setLoading] = useState(false);

  // Auth Simulation
  const handleLogin = async (email: string) => {
    setLoading(true);
    try {
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (res.ok) {
        const profile = {
          ...data,
          portfolio: data.portfolio && data.portfolio.length > 0 ? data.portfolio : [
            {
              title: "UniMatch Beta",
              link: "https://unimatch.edu",
              description: "The first version of our university builder network. Built with React and Firebase.",
              tags: ["React", "Firebase", "UI/UX"],
              image: "https://picsum.photos/seed/unimatch/800/600"
            },
            {
              title: "Campus Hub",
              link: "https://campushub.io",
              description: "A centralized platform for campus events and student organizations.",
              tags: ["Next.js", "Tailwind", "Node.js"],
              image: "https://picsum.photos/seed/campus/800/600"
            }
          ]
        };
        setUser(profile);
        if (!data.name) setView('onboarding');
        else setView('feed');
      } else {
        alert(data.error);
      }
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const updateProfile = async (profileData: Partial<UserProfile>) => {
    if (!user) return;
    try {
      await fetch(`/api/users/${user.id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...user, ...profileData })
      });
      setUser({ ...user, ...profileData } as UserProfile);
      setView('feed');
    } catch (e) {
      console.error(e);
    }
  };

  const fetchProjects = async () => {
    try {
      const res = await fetch('/api/projects');
      if (!res.ok) throw new Error('Failed to fetch projects');
      const data = await res.json();
      setProjects(data);
    } catch (e) {
      console.error("Error fetching projects:", e);
    }
  };

  const fetchMyProjects = async () => {
    if (!user) return;
    try {
      const res = await fetch(`/api/projects/my/${user.id}`);
      if (!res.ok) throw new Error('Failed to fetch my projects');
      const data = await res.json();
      setMyProjects(data);
    } catch (e) {
      console.error("Error fetching my projects:", e);
    }
  };

  const fetchChats = async () => {
    if (!user) return;
    try {
      const res = await fetch(`/api/chats/${user.id}`);
      if (!res.ok) throw new Error('Failed to fetch chats');
      const data = await res.json();
      setChats(data);
    } catch (e) {
      console.error("Error fetching chats:", e);
    }
  };

  useEffect(() => {
    if (user && user.name) {
      fetchProjects();
      fetchMyProjects();
      fetchChats();
    }
  }, [user, view]);

  // --- Views ---

  if (view === 'auth') {
    return (
      <div className="min-h-screen bg-[#E4E3E0] flex items-center justify-center p-4">
        <motion.div 
          initial={{ y: 20, opacity: 0 }}
          animate={{ y: 0, opacity: 1 }}
          className="max-w-md w-full"
        >
          <Card className="p-10">
            <div className="text-center mb-10">
              <h1 className="text-6xl font-display font-black text-black tracking-tighter mb-2 uppercase italic">UniMatch</h1>
              <p className="text-black font-display font-bold uppercase italic text-xs tracking-tight">Exclusively for university builders.</p>
            </div>
            <form onSubmit={(e: any) => {
              e.preventDefault();
              handleLogin(e.target.email.value);
            }}>
              <Input name="email" label="University Email" placeholder="you@tsinghua.edu.cn" required />
              <Button type="submit" className="w-full mt-4" disabled={loading}>
                {loading ? 'Verifying...' : 'Enter the Arena'}
              </Button>
            </form>
          </Card>
        </motion.div>
      </div>
    );
  }

  if (view === 'onboarding') {
    return (
      <div className="min-h-screen bg-[#E4E3E0] p-4 md:p-12 overflow-y-auto">
        <div className="max-w-3xl mx-auto">
          <Card className="p-10">
            <h2 className="text-4xl font-display font-black text-black mb-8 uppercase italic tracking-tighter">Character Creation</h2>
            <form onSubmit={(e: any) => {
              e.preventDefault();
              const formData = new FormData(e.target);
              updateProfile({
                name: formData.get('name') as string,
                role: formData.get('role') as any,
                major: formData.get('major') as string,
                bio: formData.get('bio') as string,
                skills: (formData.get('skills') as string).split(',').map(s => s.trim()),
                mindset: {
                  vision: parseInt(formData.get('vision') as string),
                  execution: parseInt(formData.get('execution') as string),
                  design: parseInt(formData.get('design') as string),
                  technical: parseInt(formData.get('technical') as string),
                  social: parseInt(formData.get('social') as string),
                },
                portfolio: [],
                avatar: `https://api.dicebear.com/7.x/avataaars/svg?seed=${formData.get('name')}&backgroundColor=ffadad,ffd6a5,fdffb6,caffbf,9bf6ff,a0c4ff,bdb2ff,ffc6ff,ff9b9b,9bffd6,d69bff`
              });
            }}>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
                <div className="space-y-4">
                  <Input name="name" label="Name / Nick" required />
                  <Input name="major" label="Major / Faculty" required />
                  <div className="mb-4">
                    <label className="block font-display font-black uppercase italic text-xs tracking-tight mb-1">Your Role</label>
                    <select name="role" className="w-full bg-white border-4 border-black p-3 font-bold focus:outline-none focus:bg-brand-cyan/20 transition-all">
                      <option>Student</option>
                      <option>Founder</option>
                      <option>Both</option>
                    </select>
                  </div>
                  <TextArea name="bio" label="About Me (Vibe Text)" placeholder="What drives you?" required />
                  <Input name="skills" label="Skills (Comma separated)" placeholder="React, Python, Design, Sales" required />
                </div>
                
                <div className="bg-white border-4 border-black p-6 brutalist-shadow-sm">
                  <h3 className="font-display font-black uppercase italic text-xs tracking-tight mb-6 flex items-center gap-2"><Zap size={16}/> Mindset Stats</h3>
                  {['vision', 'execution', 'design', 'technical', 'social'].map(stat => (
                    <div key={stat} className="mb-6">
                      <div className="flex justify-between font-display font-black uppercase italic text-[10px] text-black mb-2">
                        <span>{stat}</span>
                        <span id={`${stat}-val`} className="text-brand-blue">50</span>
                      </div>
                      <input 
                        type="range" 
                        name={stat} 
                        min="0" max="100" defaultValue="50" 
                        className="w-full accent-black h-2 bg-black/10 rounded-none appearance-none cursor-pointer"
                        onChange={(e) => {
                          const el = document.getElementById(`${stat}-val`);
                          if (el) el.innerText = e.target.value;
                        }}
                      />
                    </div>
                  ))}
                  <p className="text-[10px] font-display font-black text-black/60 italic mt-6 leading-relaxed uppercase">These stats generate your unique hexagonal mindset diagram.</p>
                </div>
              </div>
              <Button type="submit" variant="primary" className="w-full py-4 text-xl">Level Up & Enter</Button>
            </form>
          </Card>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-[#E4E3E0] flex flex-col">
      {/* Navigation */}
      <nav className="bg-white border-b-4 border-black p-4 sticky top-0 z-50">
        <div className="max-w-6xl mx-auto flex justify-between items-center">
          <div className="flex items-center gap-8">
            <h1 className="text-3xl font-display font-black text-black tracking-tighter cursor-pointer uppercase italic" onClick={() => setView('feed')}>UniMatch</h1>
            <div className="hidden md:flex gap-6">
              <button onClick={() => setView('feed')} className={`font-display font-black uppercase italic text-sm tracking-tight transition-colors ${view === 'feed' ? 'text-brand-blue underline underline-offset-4' : 'text-black hover:text-brand-blue'}`}>Feed</button>
              <button onClick={() => setView('dashboard')} className={`font-display font-black uppercase italic text-sm tracking-tight transition-colors ${view === 'dashboard' ? 'text-brand-blue underline underline-offset-4' : 'text-black hover:text-brand-blue'}`}>Dashboard</button>
              <button onClick={() => setView('chats')} className={`font-display font-black uppercase italic text-sm tracking-tight transition-colors ${view === 'chats' ? 'text-brand-blue underline underline-offset-4' : 'text-black hover:text-brand-blue'}`}>Chats</button>
            </div>
          </div>
          <div className="flex items-center gap-4">
            <div className="text-right hidden sm:block">
              <p className="font-display font-black uppercase italic text-xs text-black">{user?.name}</p>
              <p className="font-display font-black text-[10px] text-black/60 uppercase tracking-widest">{user?.match_count} Matches</p>
            </div>
            <img 
              src={user?.avatar} 
              className="w-12 h-12 border-4 border-black brutalist-shadow-sm cursor-pointer hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all" 
              onClick={() => setView('profile')}
            />
          </div>
        </div>
      </nav>

      <main className="flex-1 p-4 md:p-8 overflow-y-auto">
        <div className="max-w-6xl mx-auto">
          
          {view === 'feed' && (
            <div className="space-y-12">
              <div className="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                <div>
                  <h2 className="text-6xl font-display font-black text-black tracking-tighter mb-2 uppercase italic">The Arena</h2>
                  <p className="text-black font-display font-bold uppercase italic text-sm tracking-tight">Find your next big thing.</p>
                </div>
                <div className="flex gap-2 w-full md:w-auto">
                  <div className="flex-1 md:w-80 bg-white border-4 border-black flex items-center px-4 brutalist-shadow-sm">
                    <Search size={18} className="text-black mr-2"/>
                    <input placeholder="Search projects..." className="w-full py-3 font-bold text-black focus:outline-none bg-transparent" />
                  </div>
                </div>
              </div>
              
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
                {projects.map(project => (
                  <motion.div 
                    key={project.id}
                    whileHover={{ scale: 1.02 }}
                    className="h-full"
                  >
                    <Card noPadding className="h-full flex flex-col group overflow-hidden">
                      {/* Large Image Section */}
                      <div className="h-64 bg-brand-cyan/20 relative overflow-hidden border-b-4 border-black">
                        <img 
                          src={project.project_image || `https://api.dicebear.com/7.x/shapes/svg?seed=${project.title}`} 
                          className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
                          referrerPolicy="no-referrer"
                        />
                        <div className="absolute top-4 left-4">
                          <span className="bg-brand-yellow text-black px-3 py-1 border-2 border-black font-display font-black uppercase italic text-[10px] tracking-widest brutalist-shadow-sm">
                            {project.stage}
                          </span>
                        </div>
                      </div>

                      {/* Content Section */}
                      <div className="p-6 flex-1 flex flex-col">
                        <div className="flex justify-between items-start gap-4 mb-4">
                          <div className="flex-1">
                            <h3 className="text-3xl font-display font-black text-black mb-1 leading-none uppercase italic tracking-tighter group-hover:text-brand-blue transition-colors">
                              {project.title}
                            </h3>
                            <p className="text-[10px] font-display font-black text-black/60 uppercase italic tracking-widest">
                              Founded by {project.founder_name}
                            </p>
                          </div>
                          <img src={project.founder_avatar} className="w-12 h-12 border-2 border-black brutalist-shadow-sm" />
                        </div>
                        
                        <p className="text-black font-bold text-sm leading-tight mb-6 flex-1 line-clamp-3">
                          {project.pitch}
                        </p>

                        {/* Roles Required Section */}
                        <div className="space-y-3 mb-6">
                          <h4 className="text-[10px] font-display font-black text-black/60 uppercase italic tracking-widest">Roles Needed</h4>
                          <div className="flex flex-wrap gap-2">
                            {project.roles_needed.map(role => (
                              <div key={role} className="bg-white text-black px-4 py-2 border-4 border-black font-display font-black uppercase italic text-[10px] tracking-widest brutalist-shadow-sm hover:bg-brand-teal hover:text-white transition-all cursor-default">
                                {role}
                              </div>
                            ))}
                          </div>
                        </div>

                        {/* Action Buttons - Dating Style */}
                        <div className="flex gap-4 justify-center pt-6 border-t-4 border-black">
                          <button 
                            id="project-feed-dislike-btn"
                            onClick={() => {
                              setProjects(prev => prev.filter(p => p.id !== project.id));
                            }}
                            className="w-16 h-16 border-4 border-black bg-white flex items-center justify-center text-black hover:bg-brand-red hover:text-white transition-all brutalist-shadow brutalist-shadow-hover brutalist-shadow-active group"
                          >
                            <X className="w-12 h-12 flex-shrink-0 group-hover:text-white transition-colors" strokeWidth={3} />
                          </button>
                          <button 
                            id="project-feed-like-btn"
                            onClick={() => {
                              const message = prompt(`Send a 'Heart' message to ${project.founder_name}:`);
                              if (message) {
                                fetch('/api/applications', {
                                  method: 'POST',
                                  headers: { 'Content-Type': 'application/json' },
                                  body: JSON.stringify({
                                    id: Math.random().toString(36).substring(2, 15),
                                    project_id: project.id,
                                    applicant_id: user?.id,
                                    message
                                  })
                                }).then(() => {
                                  alert("It's a Match Request! ❤️");
                                  setProjects(prev => prev.filter(p => p.id !== project.id));
                                });
                              }
                            }}
                            className="w-16 h-16 border-4 border-black bg-brand-red flex items-center justify-center text-white transition-all brutalist-shadow brutalist-shadow-hover brutalist-shadow-active"
                          >
                            <Heart className="w-12 h-12 flex-shrink-0 fill-white text-white" strokeWidth={2.5} />
                          </button>
                        </div>
                      </div>
                    </Card>
                  </motion.div>
                ))}
              </div>
            </div>
          )}

          {view === 'dashboard' && (
            <div className="space-y-12">
              <div className="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                <div>
                  <h2 className="text-6xl font-display font-black text-black tracking-tighter mb-2 uppercase italic">Founder HQ</h2>
                  <p className="text-black font-display font-bold uppercase italic text-sm tracking-tight">Manage your ventures and talent.</p>
                </div>
                <Button variant="primary" onClick={() => {
                  const title = prompt("Project Title:");
                  const pitch = prompt("Pitch (max 300 chars):");
                  const roles = prompt("Roles needed (comma separated):");
                  if (title && pitch && roles) {
                    fetch('/api/projects', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({
                        id: Math.random().toString(36).substring(2, 15),
                        founder_id: user?.id,
                        title,
                        pitch,
                        stage: 'Idea',
                        roles_needed: roles.split(',').map(r => r.trim()),
                        links: ''
                      })
                    }).then(() => fetchMyProjects());
                  }
                }}>
                  <Plus className="inline mr-2" size={20} /> New Project
                </Button>
              </div>

              <div className="grid grid-cols-1 lg:grid-cols-2 gap-12">
                {myProjects.map(project => (
                  <div key={project.id} className="space-y-6">
                    <Card className="bg-brand-cyan/10 relative overflow-hidden">
                      <div className="absolute top-0 right-0 bg-black text-white px-6 py-1 font-black uppercase italic text-[10px] rotate-45 translate-x-6 translate-y-2 border-b-2 border-white">
                        {project.status === 'active' ? 'Recruiting' : 'Team Found'}
                      </div>
                      <h3 className="text-3xl font-black text-black mb-2 uppercase italic tracking-tighter">{project.title}</h3>
                      <p className="text-black font-bold text-sm mb-6 leading-tight">{project.pitch}</p>
                      <div className="flex gap-2">
                        <Button variant="secondary" className="py-2 px-4 text-xs">Edit Project</Button>
                        <Button variant="ghost" className="py-2 px-4 text-xs">Archive</Button>
                      </div>
                    </Card>
                    
                    <div className="space-y-4">
                      <h4 className="font-black uppercase italic text-xs tracking-tight text-black flex items-center gap-2">
                        <Users size={14}/> Incoming Talent
                      </h4>
                      <ApplicantList projectId={project.id} onMatch={() => {
                        fetchMyProjects();
                        fetchChats();
                      }} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {view === 'chats' && (
            <div className="h-[75vh] flex gap-8">
              <div className="w-1/3 space-y-4 overflow-y-auto pr-2">
                <h2 className="text-4xl font-display font-black text-black mb-6 uppercase italic tracking-tighter">Matches</h2>
                {chats.map(chat => (
                  <motion.div 
                    key={chat.id} 
                    whileHover={{ x: 8 }}
                    onClick={() => setActiveChat(chat)}
                    className={`p-4 border-4 border-black transition-all cursor-pointer brutalist-shadow-sm ${activeChat?.id === chat.id ? 'bg-brand-blue text-white translate-x-2 translate-y-2 shadow-none' : 'bg-white text-black hover:bg-brand-cyan/10'}`}
                  >
                    <div className="flex items-center gap-3">
                      <img src={user?.id === chat.user1_id ? chat.user2_avatar : chat.user1_avatar} className="w-12 h-12 border-2 border-black" />
                      <div className="flex-1 min-w-0">
                        <p className={`font-display font-black text-sm truncate uppercase italic tracking-tight ${activeChat?.id === chat.id ? 'text-white' : 'text-black'}`}>{chat.project_title}</p>
                        <p className={`text-[10px] font-display font-black uppercase italic tracking-widest truncate ${activeChat?.id === chat.id ? 'text-white/80' : 'text-black/60'}`}>
                          {user?.id === chat.user1_id ? chat.user2_name : chat.user1_name}
                        </p>
                      </div>
                    </div>
                  </motion.div>
                ))}
              </div>
              <div className="flex-1 flex flex-col">
                {activeChat ? (
                  <ChatWindow chat={activeChat} currentUser={user!} />
                ) : (
                  <div className="flex-1 border-4 border-black border-dashed flex items-center justify-center bg-white brutalist-shadow">
                    <div className="text-center">
                      <MessageSquare size={64} className="mx-auto mb-4 text-black/10" />
                      <p className="text-black font-black uppercase italic text-sm tracking-tight">Select a match to chat</p>
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}

          {view === 'profile' && (
            <div className="max-w-4xl mx-auto">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-12">
                <Card className="md:col-span-1 flex flex-col items-center text-center">
                  <img src={user?.avatar} className="w-48 h-48 border-4 border-black brutalist-shadow mb-6 bg-brand-cyan/10" />
                  <h2 className="text-4xl font-display font-black text-black mb-1 uppercase italic tracking-tighter">{user?.name}</h2>
                  <p className="font-display font-black text-brand-blue uppercase italic tracking-widest text-xs mb-6">{user?.role} · {user?.major}</p>
                  <div className="w-full pt-6 border-t-4 border-black flex justify-around items-center">
                    <div className="text-center">
                      <p className="text-4xl font-display font-black text-black leading-none">{user?.match_count}</p>
                      <p className="text-[10px] font-display font-black text-black/60 uppercase italic tracking-widest">Matches</p>
                    </div>
                    <Button variant="danger" className="w-14 h-14 p-0" onClick={() => window.location.reload()}>
                      <LogOut size={24} strokeWidth={3} />
                    </Button>
                  </div>
                </Card>
                
                <Card className="md:col-span-2 space-y-8">
                  <div className="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <div className="space-y-8">
                      <div>
                        <h4 className="font-display font-black uppercase italic text-xs tracking-tight mb-3 flex items-center gap-2 text-black/60"><Target size={14}/> The Vibe</h4>
                        <p className="text-xl text-black leading-tight font-black italic">"{user?.bio}"</p>
                      </div>
                      <div>
                        <h4 className="font-display font-black uppercase italic text-xs tracking-tight mb-3 flex items-center gap-2 text-black/60"><Cpu size={14}/> Arsenal</h4>
                        <div className="flex flex-wrap gap-2">
                          {Array.isArray(user?.skills) && user?.skills.map(skill => (
                            <span key={skill} className="bg-brand-teal text-white px-3 py-1 border-2 border-black font-display font-black text-[10px] uppercase italic tracking-widest brutalist-shadow-sm">
                              {skill}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                    <div className="bg-white border-4 border-black p-6 brutalist-shadow-sm">
                      <h4 className="font-display font-black uppercase italic text-xs tracking-tight mb-6 text-center text-black/60">Mindset Matrix</h4>
                      <MindsetDiagram data={user?.mindset || {}} size={220} />
                    </div>
                  </div>

                  {/* Portfolio Section */}
                  <div className="pt-8 border-t-4 border-black">
                    <h4 className="font-display font-black uppercase italic text-xs tracking-tight mb-6 flex items-center gap-2 text-black/60"><Briefcase size={14}/> Portfolio (Extended)</h4>
                    <div className="grid grid-cols-1 gap-8">
                      {user?.portfolio && user.portfolio.length > 0 ? (
                        user.portfolio.map((item, idx) => (
                          <div key={idx} className="group flex flex-col md:flex-row bg-white border-4 border-black brutalist-shadow-sm hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all overflow-hidden">
                            {item.image && (
                              <div className="md:w-48 h-48 border-b-4 md:border-b-0 md:border-r-4 border-black overflow-hidden">
                                <img src={item.image} className="w-full h-full object-cover group-hover:scale-110 transition-transform" />
                              </div>
                            )}
                            <div className="p-6 flex-1 flex flex-col">
                              <div className="flex justify-between items-start mb-2">
                                <h5 className="font-display font-black text-black text-xl uppercase italic tracking-tight group-hover:text-brand-blue transition-colors">{item.title}</h5>
                                <a href={item.link} target="_blank" rel="noopener noreferrer" className="text-black hover:text-brand-blue">
                                  <LinkIcon size={20} strokeWidth={3} />
                                </a>
                              </div>
                              <p className="text-sm text-black font-bold leading-tight mb-4 flex-1">{item.description}</p>
                              {item.tags && (
                                <div className="flex flex-wrap gap-2">
                                  {item.tags.map(tag => (
                                    <span key={tag} className="text-[9px] font-black uppercase italic tracking-widest text-black/40 border border-black/20 px-2 py-0.5">
                                      #{tag}
                                    </span>
                                  ))}
                                </div>
                              )}
                            </div>
                          </div>
                        ))
                      ) : (
                        <div className="text-center py-12 border-4 border-black border-dashed bg-black/5">
                          <p className="text-sm text-black/40 font-display font-black uppercase italic tracking-tight">No portfolio items added yet</p>
                        </div>
                      )}
                    </div>
                  </div>
                </Card>
              </div>
            </div>
          )}

        </div>
      </main>
    </div>
  );
}

function ApplicantList({ projectId, onMatch }: { projectId: string, onMatch: () => void }) {
  const [applicants, setApplicants] = useState<Application[]>([]);

  useEffect(() => {
    fetch(`/api/applications/project/${projectId}`)
      .then(res => res.json())
      .then(data => setApplicants(data));
  }, [projectId]);

  const handleDecision = async (id: string, status: 'accepted' | 'rejected') => {
    await fetch(`/api/applications/${id}/decision`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status })
    });
    setApplicants(applicants.filter(a => a.id !== id));
    if (status === 'accepted') onMatch();
  };

  return (
    <div className="grid grid-cols-1 gap-6">
      {applicants.length === 0 && <p className="text-[10px] font-black text-black/40 uppercase italic tracking-widest">No talent in queue...</p>}
      {applicants.map(app => (
        <Card key={app.id} noPadding className="overflow-hidden border-4 border-black">
          <div className="flex flex-col sm:flex-row">
            <div className="p-6 flex-1">
              <div className="flex items-center gap-4 mb-6">
                <img src={app.applicant_avatar} className="w-16 h-16 border-2 border-black brutalist-shadow-sm" />
                <div>
                  <h5 className="font-display font-black text-black text-xl uppercase italic tracking-tight">{app.applicant_name}</h5>
                  <p className="text-[10px] font-display font-black text-brand-blue uppercase italic tracking-widest">{app.applicant_major}</p>
                </div>
              </div>
              <p className="text-black font-bold text-sm italic mb-6 bg-brand-cyan/10 p-4 border-l-8 border-brand-blue">"{app.message}"</p>
              <div className="flex gap-4">
                <Button 
                  id={`applicant-match-btn-${app.id}`}
                  variant="danger" 
                  className="w-14 h-14 !p-0 rounded-none flex-shrink-0" 
                  onClick={() => handleDecision(app.id, 'accepted')}
                >
                  <Heart className="w-10 h-10 flex-shrink-0 fill-white text-white" strokeWidth={2.5} />
                </Button>
                <Button 
                  id={`applicant-pass-btn-${app.id}`}
                  variant="secondary" 
                  className="w-14 h-14 !p-0 rounded-none flex-shrink-0 group" 
                  onClick={() => handleDecision(app.id, 'rejected')}
                >
                  <X className="w-10 h-10 flex-shrink-0 group-hover:text-white transition-colors" strokeWidth={3} />
                </Button>
              </div>
            </div>
            <div className="w-full sm:w-56 bg-white border-t-4 sm:border-t-0 sm:border-l-4 border-black flex items-center justify-center p-4">
              <MindsetDiagram data={JSON.parse(app.applicant_mindset || '{}')} size={160} />
            </div>
          </div>
        </Card>
      ))}
    </div>
  );
}

function ChatWindow({ chat, currentUser }: { chat: Chat, currentUser: UserProfile }) {
  const [messages, setMessages] = useState<Message[]>([]);
  const [input, setInput] = useState('');
  const otherUser = currentUser.id === chat.user1_id ? { name: chat.user2_name, avatar: chat.user2_avatar } : { name: chat.user1_name, avatar: chat.user1_avatar };

  const fetchMessages = async () => {
    const res = await fetch(`/api/messages/${chat.id}`);
    const data = await res.json();
    setMessages(data);
  };

  useEffect(() => {
    fetchMessages();
    const interval = setInterval(fetchMessages, 3000);
    return () => clearInterval(interval);
  }, [chat.id]);

  const sendMessage = async () => {
    if (!input.trim()) return;
    await fetch('/api/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: Math.random().toString(36).substring(2, 15),
        chat_id: chat.id,
        sender_id: currentUser.id,
        content: input
      })
    });
    setInput('');
    fetchMessages();
  };

  return (
    <div className="flex-1 flex flex-col bg-white border-4 border-black brutalist-shadow overflow-hidden">
      <div className="p-4 border-b-4 border-black flex items-center gap-3 bg-brand-cyan/10">
        <img src={otherUser.avatar} className="w-12 h-12 border-2 border-black" />
        <div>
          <h3 className="font-display font-black text-black text-sm uppercase italic tracking-tight leading-none mb-1">{otherUser.name}</h3>
          <p className="text-[10px] font-display font-black text-black/60 uppercase italic tracking-widest">Project: {chat.project_title}</p>
        </div>
      </div>
      <div className="flex-1 p-6 overflow-y-auto space-y-4 bg-[#E4E3E0]/30">
        {messages.map(msg => (
          <div key={msg.id} className={`flex ${msg.sender_id === currentUser.id ? 'justify-end' : 'justify-start'}`}>
            <div className={`max-w-[80%] p-4 border-4 border-black font-bold text-sm leading-tight brutalist-shadow-sm ${msg.sender_id === currentUser.id ? 'bg-brand-blue text-white' : 'bg-white text-black'}`}>
              {msg.content}
            </div>
          </div>
        ))}
      </div>
      <div className="p-4 bg-white border-t-4 border-black flex gap-2">
        <input 
          value={input}
          onChange={(e) => setInput(e.target.value)}
          onKeyPress={(e) => e.key === 'Enter' && sendMessage()}
          placeholder="Type a message..."
          className="flex-1 font-bold text-black focus:outline-none px-4 py-2 bg-brand-cyan/5 border-2 border-black"
        />
        <Button onClick={sendMessage} className="w-14 h-14 p-0"><Send size={20} strokeWidth={3}/></Button>
      </div>
    </div>
  );
}
