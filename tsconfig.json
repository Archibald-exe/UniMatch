seedData();

async function startServer() {
  const app = express();
  const PORT = 3000;

  app.use(express.json());

  // --- API Routes ---

  // Auth Simulation (MVP)
  app.post("/api/auth/login", (req, res) => {
    const { email } = req.body;
    if (!email.endsWith(".edu.cn") && !email.endsWith(".edu")) {
      return res.status(400).json({ error: "Please use your university email." });
    }
    
    let user = db.prepare("SELECT * FROM users WHERE email = ?").get(email) as any;
    if (!user) {
      const id = Math.random().toString(36).substring(2, 15);
      db.prepare("INSERT INTO users (id, email) VALUES (?, ?)").run(id, email);
      user = { id, email };
    } else {
      if (typeof user.skills === 'string') {
        try { user.skills = JSON.parse(user.skills); } catch (e) { user.skills = []; }
      }
      if (typeof user.mindset === 'string') {
        try { user.mindset = JSON.parse(user.mindset); } catch (e) { user.mindset = {}; }
      }
      if (typeof user.portfolio === 'string') {
        try { user.portfolio = JSON.parse(user.portfolio); } catch (e) { user.portfolio = []; }
      }
    }
    res.json(user);
  });

  app.get("/api/users/:id", (req, res) => {
    const user = db.prepare("SELECT * FROM users WHERE id = ?").get(req.params.id) as any;
    if (user) {
      if (typeof user.skills === 'string') {
        try { user.skills = JSON.parse(user.skills); } catch (e) { user.skills = []; }
      }
      if (typeof user.mindset === 'string') {
        try { user.mindset = JSON.parse(user.mindset); } catch (e) { user.mindset = {}; }
      }
      if (typeof user.portfolio === 'string') {
        try { user.portfolio = JSON.parse(user.portfolio); } catch (e) { user.portfolio = []; }
      }
    }
    res.json(user);
  });

  app.put("/api/users/:id", (req, res) => {
    const { name, role, major, bio, skills, mindset, portfolio, avatar } = req.body;
    db.prepare(`
      UPDATE users 
      SET name = ?, role = ?, major = ?, bio = ?, skills = ?, mindset = ?, portfolio = ?, avatar = ?
      WHERE id = ?
    `).run(
      name, 
      role, 
      major, 
      bio, 
      Array.isArray(skills) ? JSON.stringify(skills) : skills, 
      typeof mindset === 'object' ? JSON.stringify(mindset) : mindset,
      Array.isArray(portfolio) ? JSON.stringify(portfolio) : portfolio,
      avatar, 
      req.params.id
    );
    res.json({ success: true });
  });

  // Projects
  app.post("/api/projects", (req, res) => {
    const { id, founder_id, title, pitch, stage, roles_needed, links } = req.body;
    const project_image = `https://api.dicebear.com/7.x/shapes/svg?seed=${title}`;
    db.prepare(`
      INSERT INTO projects (id, founder_id, title, pitch, stage, roles_needed, links, project_image)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `).run(id, founder_id, title, pitch, stage, JSON.stringify(roles_needed), links, project_image);
    res.json({ success: true });
  });

  app.get("/api/projects", (req, res) => {
    const projects = db.prepare(`
      SELECT p.*, u.name as founder_name, u.avatar as founder_avatar 
      FROM projects p
      JOIN users u ON p.founder_id = u.id
      WHERE p.status = 'active'
      ORDER BY p.created_at DESC
    `).all() as any[];
    
    const parsedProjects = projects.map(p => ({
      ...p,
      roles_needed: typeof p.roles_needed === 'string' ? JSON.parse(p.roles_needed) : p.roles_needed
    }));
    
    res.json(parsedProjects);
  });

  app.get("/api/projects/my/:userId", (req, res) => {
    const projects = db.prepare("SELECT * FROM projects WHERE founder_id = ?").all(req.params.userId) as any[];
    const parsedProjects = projects.map(p => ({
      ...p,
      roles_needed: typeof p.roles_needed === 'string' ? JSON.parse(p.roles_needed) : p.roles_needed
    }));
    res.json(parsedProjects);
  });

  // Applications
  app.post("/api/applications", (req, res) => {
    const { id, project_id, applicant_id, message } = req.body;
    db.prepare(`
      INSERT INTO applications (id, project_id, applicant_id, message)
      VALUES (?, ?, ?, ?)
    `).run(id, project_id, applicant_id, message);
    res.json({ success: true });
  });

  app.get("/api/applications/project/:projectId", (req, res) => {
    const apps = db.prepare(`
      SELECT a.*, u.name as applicant_name, u.avatar as applicant_avatar, u.major as applicant_major, u.mindset as applicant_mindset
      FROM applications a
      JOIN users u ON a.applicant_id = u.id
      WHERE a.project_id = ? AND a.status = 'pending'
    `).all(req.params.projectId);
    res.json(apps);
  });

  app.post("/api/applications/:id/decision", (req, res) => {
    const { status } = req.body; // 'accepted' or 'rejected'
    const application = db.prepare("SELECT * FROM applications WHERE id = ?").get(req.params.id);
    
    db.prepare("UPDATE applications SET status = ? WHERE id = ?").run(status, req.params.id);

    if (status === 'accepted') {
      const chatId = Math.random().toString(36).substring(2, 15);
      const project = db.prepare("SELECT founder_id FROM projects WHERE id = ?").get(application.project_id);
      
      db.prepare(`
        INSERT INTO chats (id, project_id, user1_id, user2_id)
        VALUES (?, ?, ?, ?)
      `).run(chatId, application.project_id, project.founder_id, application.applicant_id);

      // Update match counts
      db.prepare("UPDATE users SET match_count = match_count + 1 WHERE id = ?").run(project.founder_id);
      db.prepare("UPDATE users SET match_count = match_count + 1 WHERE id = ?").run(application.applicant_id);
    }

    res.json({ success: true });
  });

  // Chats & Messages
  app.get("/api/chats/:userId", (req, res) => {
    const chats = db.prepare(`
      SELECT c.*, p.title as project_title, 
             u1.name as user1_name, u1.avatar as user1_avatar,
             u2.name as user2_name, u2.avatar as user2_avatar
      FROM chats c
      JOIN projects p ON c.project_id = p.id
      JOIN users u1 ON c.user1_id = u1.id
      JOIN users u2 ON c.user2_id = u2.id
      WHERE c.user1_id = ? OR c.user2_id = ?
    `).all(req.params.userId, req.params.userId);
    res.json(chats);
  });

  app.get("/api/messages/:chatId", (req, res) => {
    const messages = db.prepare("SELECT * FROM messages WHERE chat_id = ? ORDER BY created_at ASC").all(req.params.chatId);
    res.json(messages);
  });

  app.post("/api/messages", (req, res) => {
    const { id, chat_id, sender_id, content, type } = req.body;
    db.prepare(`
      INSERT INTO messages (id, chat_id, sender_id, content, type)
      VALUES (?, ?, ?, ?, ?)
    `).run(id, chat_id, sender_id, content, type || 'text');
    res.json({ success: true });
  });

  // --- Vite Middleware ---
  if (process.env.NODE_ENV !== "production") {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: "spa",
    });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), "dist");
    app.use(express.static(distPath));
    app.get("*", (req, res) => {
      res.sendFile(path.join(distPath, "index.html"));
    });
  }

  app.listen(PORT, "0.0.0.0", () => {
    console.log(`Server running on http://localhost:${PORT}`);
  });
}

startServer();
